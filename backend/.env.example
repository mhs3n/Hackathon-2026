UCAR_ENV=dev
# SQLite (local dev):
UCAR_DB_URL=sqlite:///../ucar.db
# PostgreSQL (production):
# UCAR_DB_URL=postgresql+psycopg://ucar:ucar@localhost:5434/ucar
UCAR_JWT_SECRET=change-me
UCAR_JWT_ISSUER=ucar-insight
UCAR_JWT_AUDIENCE=ucar-insight-frontend
UCAR_CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173

# Gemini — get your key at https://aistudio.google.com/apikey
UCAR_GEMINI_API_KEY=your-gemini-api-key-here
UCAR_GEMINI_MODEL=gemini-2.5-flash-lite
